# =============================================================================
# Sistema de Gestión Financiera — Variables de Entorno
# Copiá este archivo como .env y completá los valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# Railway inyecta DATABASE_URL automáticamente en producción
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financiera

# -----------------------------------------------------------------------------
# CORS — orígenes permitidos (JSON array)
# En producción: reemplazar con el dominio real del frontend
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173"]

# -----------------------------------------------------------------------------
# IA — Anthropic Claude (OCR cheques + extracción de intención)
# https://console.anthropic.com/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# -----------------------------------------------------------------------------
# IA — OpenAI Whisper (transcripción de notas de voz de WhatsApp)
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------------
# Evolution API — Conexión con WhatsApp
# Documentación: https://doc.evolution-api.com
#
# IMPORTANTE: Activar WEBHOOK_BASE64=true en Evolution API para que los audios
# e imágenes lleguen ya codificados en el payload (sin necesidad de descargarlos).
# Si no está activo, el sistema los descarga automáticamente vía API.
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key-de-evolution
EVOLUTION_INSTANCE=financiera

# -----------------------------------------------------------------------------
# Seguridad del Bot
# Número de teléfono del operador autorizado (solo dígitos, con código de país)
# Ej Argentina: 5491123456789
# Si se deja vacío, el bot responderá a CUALQUIER número (solo para desarrollo).
# -----------------------------------------------------------------------------
WHATSAPP_OPERATOR_PHONE=5491123456789
