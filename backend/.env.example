# Base de datos
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financiera

# CORS (frontend local en dev, Railway URL en prod)
CORS_ORIGINS=["http://localhost:5173"]

# IA
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# WhatsApp Cloud API (Meta oficial)
# Token PERMANENTE del System User (Meta Business), no el temporal de 24h.
WHATSAPP_ACCESS_TOKEN=EAAG...
# Phone Number ID del número emisor (lo da Meta, NO es el número en sí).
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Token que elegís vos; lo pegás también en la config del webhook en Meta.
WHATSAPP_VERIFY_TOKEN=un-string-secreto-cualquiera
# App Secret de la app de Meta (recomendado: valida la firma del webhook).
WHATSAPP_APP_SECRET=tu-app-secret
# Versión de la Graph API.
WHATSAPP_API_VERSION=v21.0

# Número del operador autorizado (solo dígitos, con código de país)
# Ejemplo Argentina: 5491123456789
WHATSAPP_OPERATOR_PHONE=5491123456789

# Recordatorios de cobranza (job proactivo). Deben coincidir con la plantilla
# creada y aprobada en Meta.
WHATSAPP_RECORDATORIO_TEMPLATE=recordatorio_cuota
WHATSAPP_TEMPLATE_LANG=es_AR
