# Base de datos
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financiera

# CORS (frontend local en dev, Railway URL en prod)
CORS_ORIGINS=["http://localhost:5173"]

# IA
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://tu-evolution.railway.app
EVOLUTION_API_KEY=tu-api-key-de-evolution
EVOLUTION_INSTANCE=financiera

# Número del operador autorizado (solo dígitos, con código de país)
# Ejemplo Argentina: 5491123456789
WHATSAPP_OPERATOR_PHONE=5491123456789
