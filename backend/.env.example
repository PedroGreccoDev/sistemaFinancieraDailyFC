# Base de datos
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/financiera

# CORS (frontend local en dev, Railway URL en prod)
CORS_ORIGINS=["http://localhost:5173"]

# IA
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# WAHA (WhatsApp HTTP API — gateway no oficial, engine NOWEB)
WAHA_API_URL=https://tu-waha.railway.app
WAHA_API_KEY=tu-api-key-de-waha
WAHA_SESSION=default

# Número del operador autorizado (solo dígitos, con código de país)
# Ejemplo Argentina: 5491123456789
WHATSAPP_OPERATOR_PHONE=5491123456789

# Autenticación del panel (login)
# Clave para firmar los tokens de sesión (JWT HS256). OBLIGATORIA en producción:
# generá una aleatoria larga (p. ej. `openssl rand -hex 32`).
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
# Admin raíz: se crea al arrancar si no existe ningún admin. Si olvidás la clave,
# cambiá ADMIN_PASSWORD acá/en Railway y reiniciá para recuperar el acceso.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-clave-de-admin
# URL pública del sistema para armar los enlaces de invitación (sin barra final).
# Opcional: si queda vacía, el front usa su propio origen.
PUBLIC_BASE_URL=https://tu-dominio.app
